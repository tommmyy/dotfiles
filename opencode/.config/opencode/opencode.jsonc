{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  // "theme": "opencode",
  "theme": "gruvbox",
  // "model": "anthropic/claude-sonnet-4-5",
  // "model": "openai/gpt-5-2",
  "model": "openai/gpt-5.3-codex",
  "autoupdate": true,
  // "default_agent": "plan",
  // https://opencode.ai/docs/keybinds/
  "keybinds": {
    "messages_page_up": "ctrl+alt+u",
    "messages_page_down": "ctrl+alt+d",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    // "input_line_home": "<leader>_",
    // "input_line_end": "<leader>$",
  },
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true,
      "timeout": 30000,
    },
    "slack": {
      "command": [
        "npx",
        "-y",
        "slack-mcp-server@latest",
        "--transport",
        "stdio",
      ],
      "type": "local",
      "environment": {
        // NOTE: set in zsh
        // "SLACK_MCP_XOXP_TOKEN": "${env:SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "true",
        "SLACK_MCP_ENABLED_TOOLS": "conversations_history, conversations_replies, conversations_add_message, reactions_add, reactions_remove, attachment_get_data, conversations_search_messages, channels_list, usergroups_list, usergroups_me, usergroups_create, usergroups_update, usergroups_users_update",
      },
    },
    // "slack": {
    //   "type": "remote",
    //   "url": "https://mcp.slack.com/mcp",
    //   "oauth": {
    //     "clientId": "16731258738.10610832264609",
    //     "clientSecret": "d2c0aadc7afabffbc85df6de9f49a45a",
    //   },
    //   "enabled": true,
    //   "timeout": 30000,
    // },
    // "slack": {
    //   "type": "local",
    //   // run with node; you can use tsx/bun/deno too
    //   "command": ["node", "/Users/tommmyy/workspaces/slack-mcp/dist/index.js"],
    //   "enabled": true,
    //   "environment": {
    //     "SLACK_BOT_TOKEN": "{env:SLACK_BOT_TOKEN}",
    //   },
    // },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--headless"],
      "enabled": true,
      "timeout": 30000,
    },
  },
  "plugin": ["opencode-openai-codex-auth"],
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": ["reasoning.encrypted_content"],
        "store": false,
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.2-codex": {
          "name": "GPT 5.2 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.1-codex": {
          "name": "GPT 5.1 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT 5.1 Codex Mini (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.1": {
          "name": "GPT 5.1 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "low",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "high",
            },
          },
        },
      },
    },
  },
}
