#!/usr/bin/env node

const { readFileSync, existsSync } = require("fs");
const { homedir } = require("os");
const { join } = require("path");
const { spawnSync } = require("child_process");

function loadJsonConfig(configPath, label) {
	if (!existsSync(configPath)) return {};
	try {
		return JSON.parse(readFileSync(configPath, "utf8"));
	} catch (e) {
		log(`warning: failed to parse ${label} ${configPath}: ${e.message}`);
		return {};
	}
}

function loadGlobalConfig() {
	const xdgConfigHome =
		process.env.XDG_CONFIG_HOME || join(homedir(), ".config");
	const configPaths = [
		join(xdgConfigHome, "linear-session", "config.json"),
		join(
			__dirname,
			"..",
			"..",
			"..",
			".config",
			"linear-session",
			"config.json",
		),
	];
	console.log(configPaths);

	for (const configPath of configPaths) {
		if (!existsSync(configPath)) continue;
		return loadJsonConfig(configPath, "global config");
	}

	return {};
}

function resolvePreset(globalConfig, projectName) {
	if (!projectName) return {};
	const presets = globalConfig.projects || {};
	const preset = presets[projectName];
	if (!preset || typeof preset !== "object") {
		fail(`Unknown project preset: ${projectName}`);
	}
	return preset;
}

function usage() {
	process.stderr.write(`Usage: linear-session [options] <LINEAR_ISSUE_ID>

Options:
  -i, --implement           Launch opencode in the spawned tmux session
  -P, --project <name>      Use a named project preset from config
  -r, --repo-path <path>    Repository path to run wt in (defaults to current git repo)
  -p, --prompt <text>       Extra implementation guidance
  -f, --feature-name <text> Hint for the branch/session name (e.g. "adding a test")
  -h, --help                Show this help

Examples:
  linear-session CUS-123
  linear-session --project sdp CUS-123
  linear-session --implement CUS-123
  linear-session -i -p "Focus on API timeout config" CUS-123
  linear-session -f "adding a test" CUS-123

Global config (~/.config/linear-session/config.json):
  Use this for project presets that select a repo before the issue is resolved.
  Preferred keys:
    repoPath    Repository path for the preset.
    baseBranch  Branch to check out in the main repo before creating the worktree.
    baseFolder  After switching worktree, cd into this folder if it exists.

  Example config:
    {
      "projects": {
        "sdp": {
          "repoPath": "~/workspaces/sdp",
	          "baseBranch": "develop",
	          "baseFolder": "frontend/app"
        }
      }
    }

Legacy repo config (.wtconfig):
  Removed. Use ~/.config/linear-session/config.json presets instead.
`);
}

function log(message) {
	process.stderr.write(`[linear-session] ${message}\n`);
}

function fail(message, extra) {
	process.stderr.write(`${message}\n`);
	if (extra) {
		process.stderr.write(`${extra}\n`);
	}
	process.exit(1);
}

function shellQuote(value) {
	if (value.length === 0) return "''";
	return `'${value.replace(/'/g, `'"'"'`)}'`;
}

function run(command, args, options = {}) {
	const result = spawnSync(command, args, {
		encoding: "utf8",
		stdio: options.stdio || ["ignore", "pipe", "pipe"],
		cwd: options.cwd,
		env: options.env || process.env,
	});

	if (result.error) {
		fail(`Failed to run ${command}: ${result.error.message}`);
	}

	if (options.check !== false && result.status !== 0) {
		fail(
			`Command failed: ${command} ${args.join(" ")}`,
			[result.stdout, result.stderr].filter(Boolean).join("\n").trim(),
		);
	}

	return result;
}

function requireCmd(command) {
	const result = run("sh", ["-lc", `command -v ${shellQuote(command)}`], {
		check: false,
	});
	if (result.status !== 0) {
		fail(`Missing required command: ${command}`);
	}
}

function parseArgs(argv) {
	let implement = false;
	let projectName = "";
	let repoPath = "";
	let extraPrompt = "";
	let featureName = "";
	const positional = [];

	for (let i = 0; i < argv.length; i += 1) {
		const arg = argv[i];
		if (arg === "-i" || arg === "--implement") {
			implement = true;
			continue;
		}
		if (arg === "-P" || arg === "--project" || arg === "--preset") {
			projectName = argv[i + 1] || "";
			if (!projectName) fail(`Missing value for ${arg}`);
			i += 1;
			continue;
		}
		if (arg === "-r" || arg === "--repo-path") {
			repoPath = argv[i + 1] || "";
			if (!repoPath) fail(`Missing value for ${arg}`);
			i += 1;
			continue;
		}
		if (arg === "-p" || arg === "--prompt") {
			extraPrompt = argv[i + 1] || "";
			if (!extraPrompt) fail(`Missing value for ${arg}`);
			i += 1;
			continue;
		}
		if (arg === "-f" || arg === "--feature-name") {
			featureName = argv[i + 1] || "";
			if (!featureName) fail(`Missing value for ${arg}`);
			i += 1;
			continue;
		}
		if (arg === "-h" || arg === "--help") {
			usage();
			process.exit(0);
		}
		if (arg === "--") {
			positional.push(...argv.slice(i + 1));
			break;
		}
		if (arg.startsWith("-")) {
			fail(`Unknown option: ${arg}`);
		}
		positional.push(arg);
	}

	return {
		implement,
		projectName,
		repoPath,
		extraPrompt,
		featureName,
		issueId: positional[0] || "",
	};
}

function expandHomePath(value) {
	if (!value || !value.startsWith("~/")) return value;
	return join(homedir(), value.slice(2));
}

function resolveRepoPath(repoPath) {
	if (repoPath) {
		const resolved = run(
			"git",
			["-C", repoPath, "rev-parse", "--show-toplevel"],
			{ check: false },
		);
		if (resolved.status !== 0) {
			fail("Could not determine a git repository. Use --repo-path <path>.");
		}
		return resolved.stdout.trim();
	}

	const resolved = run("git", ["rev-parse", "--show-toplevel"], {
		check: false,
	});
	if (resolved.status !== 0) {
		fail("Could not determine a git repository. Use --repo-path <path>.");
	}
	return resolved.stdout.trim();
}

function buildPromptForFeatureMetadata(issueId, extraPrompt, featureName) {
	const featureNameRule = featureName
		? `\n9. IMPORTANT: The user provided a feature name hint: "${featureName}". Use this hint to derive the <short-kebab-title> portion of branch and session names instead of inferring from the issue title.`
		: "";

	return `Fetch Linear issue ${issueId} and return only compact JSON with this exact shape:
{"branch":"feature/CUS-1-short-description","session":"cus-1-short-description","title":"Issue title","prompt":"Implementation prompt or empty string"}

Rules:
1. Infer branch prefix from the Linear task labels. If task has label:
   - "Bug" -> fix
   - "Docs" -> chore
   - Otherwise -> feature
2. Branch format must be <type>/<ISSUE-ID>-<short-kebab-title>.
3. Session format must be <issue-id-lowercase>-<short-kebab-title> and must not contain slash.
4. If taskId starts with "CUS" (e.g. CUS-12) add project name attached to issue to <short-kebab-title>
5. Keep the slug short.
6. Prompt should be a concise implementation prompt built from the issue title and description.
7. If the extra guidance below is non-empty, include it in the prompt. If it is empty, omit it.
8. Output JSON only. No markdown. No prose.${featureNameRule}

Extra guidance:
${extraPrompt}`;
}

function runOpencode(repoPath, prompt) {
	log("asking opencode to derive branch and session");
	const result = run(
		"opencode",
		[
			"run",
			"-m",
			"openai/gpt-5.4-mini",
			"--format",
			"json",
			"--dir",
			repoPath,
			prompt,
		],
		{ check: false },
	);
	if (result.status !== 0) {
		fail(
			"opencode did not return a final response.",
			result.stderr || result.stdout,
		);
	}

	const texts = [];
	for (const line of result.stdout.split("\n")) {
		if (!line.trim()) continue;
		try {
			const event = JSON.parse(line);
			if (
				event.type === "text" &&
				event.part &&
				typeof event.part.text === "string"
			) {
				texts.push(event.part.text);
			}
		} catch (_) {
			// Ignore non-JSON lines defensively.
		}
	}

	const finalText = texts[texts.length - 1];
	if (!finalText) {
		fail("opencode did not return a final response.", result.stdout);
	}

	try {
		return JSON.parse(finalText);
	} catch (_) {
		fail("Could not parse opencode response as expected JSON.", finalText);
	}
}

function tmuxHasSession(sessionName) {
	const result = run("tmux", ["has-session", "-t", sessionName], {
		check: false,
	});
	return result.status === 0;
}

function branchExists(repoPath, branchName) {
	const local = run(
		"git",
		[
			"-C",
			repoPath,
			"show-ref",
			"--verify",
			"--quiet",
			`refs/heads/${branchName}`,
		],
		{ check: false },
	);
	if (local.status === 0) return true;
	const remote = run(
		"git",
		[
			"-C",
			repoPath,
			"show-ref",
			"--verify",
			"--quiet",
			`refs/remotes/origin/${branchName}`,
		],
		{ check: false },
	);
	return remote.status === 0;
}

function resolveUniqueBranch(repoPath, baseBranch) {
	if (!branchExists(repoPath, baseBranch)) return baseBranch;
	let counter = 1;
	while (branchExists(repoPath, `${baseBranch}-${counter}`)) {
		counter += 1;
	}
	return `${baseBranch}-${counter}`;
}

function attachOrSwitch(sessionName) {
	if (process.env.TMUX) {
		const result = spawnSync("tmux", ["switch-client", "-t", sessionName], {
			stdio: "inherit",
		});
		process.exit(result.status ?? 1);
	}
	const result = spawnSync("tmux", ["attach", "-t", sessionName], {
		stdio: "inherit",
	});
	process.exit(result.status ?? 1);
}

function main() {
	const {
		implement,
		projectName,
		repoPath: inputRepoPath,
		extraPrompt,
		featureName,
		issueId,
	} = parseArgs(process.argv.slice(2));
	if (!issueId) {
		usage();
		process.exit(1);
	}

	log(`starting for issue ${issueId}`);

	for (const command of ["opencode", "tmux", "wt", "git"]) {
		requireCmd(command);
	}

	const globalConfig = loadGlobalConfig();
	console.log(globalConfig);
	const preset = resolvePreset(globalConfig, projectName);
	const repoPath = resolveRepoPath(
		expandHomePath(inputRepoPath || preset.repoPath || ""),
	);
	log(`using repo ${repoPath}`);

	const response = runOpencode(
		repoPath,
		buildPromptForFeatureMetadata(issueId, extraPrompt, featureName),
	);
	const suggestedBranch = response.branch || "";
	const suggestedSession = response.session || "";
	const issueTitle = response.title || "";
	let implementPrompt = response.prompt || "";

	if (!suggestedBranch || !suggestedSession) {
		fail(
			"Could not parse opencode response as expected JSON.",
			JSON.stringify(response),
		);
	}

	log(`resolved branch=${suggestedBranch} session=${suggestedSession}`);

	if (tmuxHasSession(suggestedSession)) {
		log("tmux session already exists, switching to it");
		process.stdout.write(
			`Session: ${suggestedSession}\nBranch: ${suggestedBranch}\n`,
		);
		attachOrSwitch(suggestedSession);
	}

	// Resolve branch name collisions by appending a counter suffix
	const branchName = resolveUniqueBranch(repoPath, suggestedBranch);
	const sessionName =
		branchName !== suggestedBranch
			? suggestedSession + branchName.slice(suggestedBranch.length)
			: suggestedSession;

	if (branchName !== suggestedBranch) {
		log(
			`branch collision detected, using ${branchName} (session: ${sessionName})`,
		);
	}

	let wtCommand = "wt switch -v";
	if (!branchExists(repoPath, branchName)) {
		wtCommand = "wt switch --create";
	}
	log(`using worktrunk command: ${wtCommand}`);

	if (implement && !implementPrompt) {
		implementPrompt = `Implement Linear issue ${issueId}.`;
		if (issueTitle) {
			implementPrompt += `\n\nTitle: ${issueTitle}`;
		}
		if (extraPrompt) {
			implementPrompt += `\n\nAdditional guidance:\n${extraPrompt}`;
		}
	}

	const baseBranch = preset.baseBranch || "";
	const baseFolder = preset.baseFolder || preset.subdir || "";

	let sendCmd = "";
	if (baseBranch) {
		sendCmd += `git checkout ${shellQuote(baseBranch)} && `;
	}
	sendCmd += `${wtCommand} ${shellQuote(branchName)}`;
	if (baseFolder) {
		sendCmd += ` && [ -d ${shellQuote(baseFolder)} ] && cd ${shellQuote(baseFolder)}`;
	}
	if (implement) {
		sendCmd += ` && opencode --prompt ${shellQuote(implementPrompt)}`;
	}

	log(`creating tmux session ${sessionName}`);
	run("tmux", ["new-session", "-d", "-s", sessionName, "-c", repoPath]);
	run("tmux", ["send-keys", "-t", sessionName, sendCmd, "Enter"]);

	log("session created, attaching");
	process.stdout.write(`Session: ${sessionName}\nBranch: ${branchName}\n`);
	attachOrSwitch(sessionName);
}

main();
