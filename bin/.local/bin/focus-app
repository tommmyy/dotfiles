#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
fi

if [[ -z $selected ]]; then
    exit 0
fi


activateByPid() {
  osascript -e "
    tell application \"System Events\"
      set frontmost of the first process whose unix id is ${1} to true
    end tell
  "
}

runAppByName() {
	# open -g -a "iTerm" && osascript -e "tell application \"System Events\" to set frontmost of process \"iTerm2\" to true"
	open -a "$1"
}

# activateByPid $(pgrep -x "$selected")
runAppByName "$selected"
